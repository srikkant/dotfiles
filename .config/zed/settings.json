// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_buffer_font_size": 13.0,
  "theme": {
    "mode": "light",
    "light": "Alabaster BG Light",
    "dark": "Alabaster BG Light"
  },
  "agent_ui_font_size": 14.0,
  "ui_font_size": 14.0,
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false,
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
    "button": false,
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "ui_font_family": "Overpass",
  "edit_predictions": {
    "open_ai_compatible_api": {
      "model": ""
    },
    "mode": "subtle",
    "provider": "zed",
  },
  "scrollbar": {
    "show": "never",
  },
  "which_key": {
    "enabled": true,
  },
  "tab_bar": {
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
    "show": false,
  },
  "title_bar": {
    "show_branch_name": false,
  },
  "buffer_line_height": "standard",
  "buffer_font_family": "Overpass Mono",
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
  "agent": {
    "default_model": {
      "provider": "opencode",
      "model": "minimax-m2.5-free",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "buffer_font_size": 13,
  "unstable.ui_density": "compact",
}
